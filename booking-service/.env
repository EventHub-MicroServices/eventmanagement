# [CONFIGMAP] Service Port
PORT=8003

# [CONFIGMAP] Database Connection (PostgreSQL)
DB_HOST=postgres-db
DB_PORT=5432
DB_NAME=booking_db

# [SECRET] Database Credentials
DB_USER=admin
DB_PASSWORD=adminpass

# [CONFIGMAP] Internal Service URLs
EVENTS_SERVICE_URL=http://events-service:8002

# [SECRET] RabbitMQ Connections
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
