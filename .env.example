# ==============================================================================
# MASTER ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# This file serves as a blueprint for configuring the microservices.
# In a Kubernetes environment:
# - [CONFIGMAP]: Non-sensitive variables (hosts, ports, paths).
# - [SECRET]: Sensitive variables (passwords, tokens, keys).
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# 1. INFRASTRUCTURE CONFIGURATION (ConfigMap)
# ------------------------------------------------------------------------------
DB_HOST=postgres-db
DB_PORT=5432
DB_NAME=postgres

MONGO_HOST=events-db
MONGO_PORT=27017

REDIS_HOST=notification-redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ------------------------------------------------------------------------------
# 2. SERVICE NETWORKING (ConfigMap)
# ------------------------------------------------------------------------------
USERS_SERVICE_URL=http://users-service:8001
EVENTS_SERVICE_URL=http://events-service:8002
BOOKING_SERVICE_URL=http://booking-service:8003
PAYMENT_SERVICE_URL=http://payment-service:8004
TICKET_SERVICE_URL=http://ticket-service:8005
NOTIFICATION_SERVICE_URL=http://notification-service:8006
AI_SERVICE_URL=http://ai-service:8007
ADMIN_SERVICE_URL=http://admin-service:8008

# ------------------------------------------------------------------------------
# 3. SECURITY & CREDENTIALS (Secret)
# ------------------------------------------------------------------------------
# [IMPORTANT] Use secure passwords in production!
DB_USER=admin
DB_PASSWORD=adminpass

# Docker Image specific credentials (for ConfigMap direct mount)
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpass

MONGO_USER=admin
MONGO_PASSWORD=adminpass
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpass

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ------------------------------------------------------------------------------
# 4. EXTERNAL API KEYS (Secret)
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. ORCHESTRATION HINTS
# ------------------------------------------------------------------------------
# List of databases for init-db.sh to create on startup (comma-separated)
POSTGRES_MULTIPLE_DATABASES=users_db,booking_db,payment_db,ticket_db
